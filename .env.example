# Database connection (Azure PostgreSQL Flexible Server)
DATABASE_URL=postgresql://user:password@host.postgres.database.azure.com:5432/dbname?sslmode=require

# Session secret (change this to a random string)
SESSION_SECRET=change-me-to-something-random-and-long

# Environment
NODE_ENV=production

# Port (Azure App Service sets this automatically)
PORT=8080

# App URL (used in email links)
APP_URL=https://jmos-wv.azurewebsites.net

# MySQL connection via ngrok tunnel
MYSQL_HOST=7.tcp.ngrok.io
MYSQL_PORT=22874
MYSQL_USER=powerBI
MYSQL_PASSWORD=ignitionData
MYSQL_DATABASE=JMWVL2

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=JMOS Dashboard <onboarding@resend.dev>
REPORT_EMAILS=email1@example.com,email2@example.com
REPORT_HOUR=6

# Timezone
TZ=America/New_York
